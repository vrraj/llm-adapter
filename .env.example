# Example environment for llm-adapter demo

# OpenAI
OPENAI_API_KEY=""

# Gemini via SDK and OpenAI-compatible adapter
GEMINI_API_KEY=""
GEMINI_OPENAI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"

# Allowed list for Models (Registry Keys) from Model Registry
# 
# IMPORTANT: Leave this empty to allow ALL models (default behavior)
# Set to comma-separated list to restrict access to specific models only
#
# Examples:
# LLM_ADAPTER_ALLOWED_MODELS=                                    # Allow all models (recommended for development)
# LLM_ADAPTER_ALLOWED_MODELS="openai:gpt-4o-mini,gemini:native-sdk-reasoning-2.5-flash"  # Allow only specific models

LLM_ADAPTER_ALLOWED_MODELS=
